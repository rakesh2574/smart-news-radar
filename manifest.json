{
  "manifest_version": 3,
  "name": "Smart News Radar",
  "version": "1.0.0",
  "description": "Fetch the latest news on any topic with optional AI-powered analysis. Save favorite topics for one-click access.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://gnews.io/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart News Radar",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
